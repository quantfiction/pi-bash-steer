{
  "name": "pi-bash-steer",
  "version": "0.3.0",
  "description": "Pi extension that intercepts long-running bash invocations (project-declared verification targets, universal footguns like find/grep -r) and steers agents to non-blocking alternatives.",
  "license": "MIT",
  "author": "quantfiction",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "bash",
    "steer",
    "mise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/quantfiction/pi-bash-steer"
  },
  "bugs": {
    "url": "https://github.com/quantfiction/pi-bash-steer/issues"
  },
  "homepage": "https://github.com/quantfiction/pi-bash-steer#readme",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.10.0",
    "@types/shell-quote": "^1.7.5",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "shell-quote": "^1.8.4",
    "smol-toml": "^1.6.1"
  }
}
